# Eliza Town — local ElizaOS server
# Copy to .env or use the root .env (recommended). Root .env is loaded first.

# --- OpenRouter (required for agent chat) ---
OPENROUTER_API_KEY=
# Free auto-router ($0)
OPENROUTER_SMALL_MODEL=openrouter/free
OPENROUTER_LARGE_MODEL=openrouter/free
# Free embeddings ($0) — 2048 dimensions
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
OPENROUTER_EMBEDDING_DIMENSIONS=2048

# --- Database ---
PGLITE_DATA_DIR=./data/pglite

# Agents spawn on demand via POST /api/agents (set true to start default agent at boot)
# ELIZA_START_DEFAULT_AGENT=true

# Defer Circle x402 paywall server (prevents 30s init timeout)
AUTO_START_X402_SERVER=false

# --- Circle wallet plugin (optional) ---
# ENABLE_CIRCLE_PLUGIN=true
CIRCLE_API_KEY=
ENTITY_SECRET=
CIRCLE_DEFAULT_CHAIN=ARC-TESTNET
CIRCLE_NETWORK=TESTNET

# --- Optional: x402 nanopayments ---
# X402_PRIVATE_KEY=
# SERVER_ADDRESS=
# SERVER_PRIVATE_KEY=
# X402_PAYWALL_PORT=4021
