# =============================================================================
# Eliza Town — starter environment (copy to .env and fill in your keys)
# =============================================================================
# Quick start:
#   1. cp .env.example .env
#   2. Set OPENROUTER_API_KEY (get one at https://openrouter.ai/keys)
#   3. npx convex dev   → creates/updates .env.local with VITE_CONVEX_URL
#   4. npm run dev
#
# Convex reads .env.local automatically. Eliza server reads .env then .env.local.

# --- OpenRouter (recommended — one key for NPC chat + embeddings) ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Free auto-router ($0) — picks from OpenRouter's free model pool
OPENROUTER_SMALL_MODEL=openrouter/free
OPENROUTER_LARGE_MODEL=openrouter/free
# Free embeddings ($0) — 2048 dimensions
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
OPENROUTER_EMBEDDING_DIMENSIONS=2048

# --- Convex (auto-filled by `npx convex dev` into .env.local) ---
# VITE_CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_DEPLOYMENT=dev:your-deployment

# --- ElizaOS local server ---
ELIZA_SERVER_URL=http://localhost:3000
PGLITE_DATA_DIR=./eliza-server/data/pglite
AUTO_START_X402_SERVER=false

# --- Circle wallet plugin (optional — leave blank to skip wallet tools) ---
CIRCLE_API_KEY=
ENTITY_SECRET=
CIRCLE_ENTITY_SECRET=
CIRCLE_DEFAULT_CHAIN=ARC-TESTNET
CIRCLE_NETWORK=TESTNET
CIRCLE_WALLET_ID=
# Demo send destination (Arc Testnet) — used by in-game CIRCLE_SEND_USDC
SERVER_ADDRESS=
# SERVER_PRIVATE_KEY=
# X402_PAYWALL_PORT=4021

# --- Optional: AI character sprite generation ---
# GOOGLE_API_KEY=
# REPLICATE_API_TOKEN=
